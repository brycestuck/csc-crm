modules = ["nodejs-20"]
run = "npm run dev"
hidden = [".config", ".git", "node_modules", ".next", "drizzle"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3000
externalPort = 80

[env]
PORT = "3000"
